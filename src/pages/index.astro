---
// Single-page project hub (DESIGN.md "Layout"). Section order: hero ->
// projects -> about -> contact. Projects render live from the `projects`
// content collection via ProjectList (filters status === 'live', sorts per
// src/lib/projects.ts). Real contact URLs sourced from the pre-rebuild
// index.astro (git show f46b07e:src/pages/index.astro) and Footer.astro.
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectList from '../components/ProjectList.astro';
import korabPhoto from '../assets/korab.png';
---
<BaseLayout
  title="Korab Eland | Project Hub"
  description="A curated index of what Korab Eland builds — proof of building with AI, for CX, PM, and AI-strategy audiences."
>
    <section id="hero" class="hero">
        <div class="hero-text">
            <p class="kicker">Korab Eland &mdash; builds with AI</p>
            <h1>Ambiguous problems, working systems.</h1>
            <p class="hero-subtitle">A curated index of what I've actually shipped &mdash; each one links straight to the repo.</p>
        </div>
        <Image src={korabPhoto} alt="Korab Eland" class="hero-photo" width={220} height={220} />
    </section>

    <section id="projects" class="section">
        <div class="container">
            <p class="section-label">Projects</p>
            <ProjectList />
        </div>
    </section>

    <section id="about" class="section">
        <div class="container">
            <p class="section-label">About</p>
            <p class="about-copy">I work at the intersection of CX, product, and AI &mdash; and I build the tools myself instead of just specifying them. Every project here started as a real problem I needed solved, not a portfolio exercise.</p>
            <p class="about-copy">For the fuller picture &mdash; who I am, how I think, what I'm writing &mdash; visit <a href="https://korabeland.com">korabeland.com</a>.</p>
        </div>
    </section>

    <section id="contact" class="section">
        <div class="container">
            <p class="section-label">Contact</p>
            <ul class="contact-row">
                <li><a href="mailto:korabeland@gmail.com?subject=Hello%20Korab">Email</a></li>
                <li><a href="https://github.com/korabeland" target="_blank" rel="noopener noreferrer">GitHub</a></li>
                <li><a href="https://www.linkedin.com/in/korabeland" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
                <li><a href="/assets/resume/Korab_Eland_Resume.pdf" target="_blank" rel="noopener noreferrer">Resume</a></li>
            </ul>
        </div>
    </section>
</BaseLayout>

<style>
    .hero {
        max-width: var(--max-width);
        padding: var(--space-2xl) var(--space-lg) var(--space-xl);
        margin: 0 auto;
        display: flex;
        align-items: flex-start;
        gap: var(--space-xl);
    }

    .hero-text {
        max-width: 430px;
    }

    .hero h1 {
        margin: var(--space-sm) 0;
    }

    .hero-subtitle {
        color: var(--text-muted);
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 0;
    }

    /* Border radius: 0, no shadow/glow (DESIGN.md Decoration) — a hairline
       border is the only treatment, matching the divider/border-bottom
       language used elsewhere (ProjectRow, Header). */
    .hero-photo {
        flex-shrink: 0;
        width: 220px;
        height: 220px;
        object-fit: cover;
        border: 1px solid var(--border);
    }

    /* DESIGN.md Spacing: "Section padding: 96-128px vertical" -> --space-2xl
       (112px, the token that actually falls in that range). */
    .section {
        padding: var(--space-2xl) 0;
    }

    .about-copy {
        max-width: 430px;
    }

    /* --accent-hover, not --accent: the base `a { color: var(--accent) }`
       rule in global.css fails WCAG AA as resting link-text color in light
       mode (~2.98:1 against --bg, needs 3:1) — see the same note in
       ProjectRow.astro and Footer.astro. --accent-hover clears AA (4.70:1). */
    .about-copy a {
        color: var(--accent-hover);
        text-decoration: underline;
    }

    .contact-row {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-md);
        list-style: none;
        margin: 0;
        padding: 0;
        font-family: var(--font-mono);
        font-size: 0.85rem;
    }

    /* --text at rest, not --accent, for the same reason as .about-copy a
       above — resting --accent text fails AA in light mode. --accent-hover
       is safe to use on :hover below. */
    .contact-row a {
        color: var(--text);
        text-decoration: none;
        border-bottom: 1px solid var(--border);
        padding-bottom: 2px;
        transition: color var(--motion-duration) var(--motion-easing),
            border-color var(--motion-duration) var(--motion-easing);
    }

    .contact-row a:hover {
        color: var(--accent-hover);
        border-color: var(--accent-hover);
    }

    @media (max-width: 640px) {
        .hero {
            padding: var(--space-xl) var(--space-lg);
            flex-direction: column;
            align-items: flex-start;
            gap: var(--space-lg);
        }

        .hero-photo {
            width: 160px;
            height: 160px;
        }
    }
</style>
