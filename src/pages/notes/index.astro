---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const notes = await getCollection('notes');
// Sort by date descending (newest first)
const sorted = notes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recent = sorted.slice(0, 3);
---

<BaseLayout title="Field Notes — Korab Eland" description="Short-form notes on decisions, frameworks, and lessons learned.">
    <section class="container" style={{ paddingTop: 'var(--spacing-2xl)' }}>
        <h1>Field Notes</h1>
        <p class="section-intro">Short-form notes on decisions, frameworks, and lessons learned. Not polished case studies — just thinking out loud.</p>
    </section>

    {sorted.length > 0 ? (
        <section id="notes-list">
            <div class="container">
                <div class="notes-grid">
                    {sorted.map((note) => (
                        <article class="note-card">
                            <time class="note-date" datetime={note.data.date.toISOString().split('T')[0]}>
                                {note.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}
                            </time>
                            <h3><a href={`/notes/${note.slug}/`}>{note.data.title}</a></h3>
                            {note.data.tags && note.data.tags.length > 0 && (
                                <div class="note-tags">
                                    {note.data.tags.map((tag) => <span>{tag}</span>)}
                                </div>
                            )}
                            {note.data.excerpt && <p class="note-excerpt">{note.data.excerpt}</p>}
                        </article>
                    ))}
                </div>
            </div>
        </section>
    ) : (
        <section class="container">
            <p>No notes yet. Check back soon.</p>
        </section>
    )}

    <slot />
</BaseLayout>
